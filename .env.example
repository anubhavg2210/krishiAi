# =====================================================
# Kisan AI Sahayak - Environment Variables
# =====================================================
# IMPORTANT: Never commit this file to git / version control.
# .env files with *.local suffix are auto-ignored by Vite.
# Rename this file to .env.local for best practice.
# =====================================================

# --- OpenWeatherMap API Key ---
# Sign up FREE at: https://openweathermap.org/api
# Steps:
#   1. Go to https://home.openweathermap.org/users/sign_up
#   2. Confirm your email
#   3. Go to "API keys" tab in your account
#   4. Copy the default key (or create a new one)
#   5. Paste it below (replace YOUR_API_KEY_HERE)
# Note: New keys activate within 10-60 minutes of signup.
# Free tier allows 1,000 calls/day, perfect for this app.
# =====================================================
VITE_OPENWEATHER_API_KEY=https://api.open-meteo.com/v1/forecast?latitude=52.52&longitude=13.41&hourly=temperature_2m