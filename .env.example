# =====================================================
# Kisan AI Sahayak - Environment Variables
# =====================================================
# IMPORTANT: Never commit your actual `.env` file to Git.
# This `.env.example` file is safe to commit.
# Copy this file to `.env` and fill in your actual API keys.
# =====================================================

# -------------------------
# FRONTEND CONFIGURATION
# -------------------------
# The Gemini API Key is required to power the AI Voice Assistant.
# Get it from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.5-flash

# Backend API URL (development)
VITE_API_URL=http://127.0.0.1:8000

# -------------------------
# BACKEND CONFIGURATION
# -------------------------
# The OpenWeatherMap API Key is required for weather data in the backend.
# Get it from: https://openweathermap.org/api
# NOTE: The application also works with Open-Meteo (free, no API key needed)
API_KEY=your_open_weather_map_api_key_here

# Backend Host and Port (for development)
# Leave as is for local development, change for production
HOST=127.0.0.1
PORT=8000

